{
  "name": "clang-rename",
  "version": "1.0.0",
  "description": "Cross-platform batch file rename utility",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:all": "npm run build && electron-builder --mac --win"
  },
  "keywords": [
    "electron",
    "vue",
    "rename",
    "batch",
    "files"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.6.0",
    "electron": "^22.3.27",
    "electron-builder": "^23.6.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^1.8.0"
  }
}
